SCANNER_MODEL=grok-4-fast

TAVILY_API_KEY=your_tavily_api_key
COINGECKO_API_KEY=your_coingecko_api_key

HF_TOKEN=your_huggingface_api_token

R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_PUBLIC_URL=https://your_r2_public_url

TWITTERAPI_BASE_URL=https://api.twitterapi.io
TWITTERAPI_API_KEY=your_twitterapi_io_api_key
TWITTERAPI_PROXY=http://username:password@proxy_host:proxy_port
TWITTERAPI_LOGIN_COOKIES=
TWITTERAPI_USER_NAME=
TWITTERAPI_EMAIL=
TWITTERAPI_PASSWORD=
TWITTERAPI_TOTP_SECRET=

OMEN_MCP_HOST=127.0.0.1
OMEN_MCP_PORT=7100
OMEN_MCP_ROUTER_URL=http://127.0.0.1:9003
OMEN_MCP_PUBLIC_BASE_URL=http://127.0.0.1:7100
OMEN_MCP_REGISTER_RETRIES=20
OMEN_MCP_REGISTER_RETRY_DELAY_MS=1500
