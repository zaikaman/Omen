{
  "name": "omen-backend",
  "private": true,
  "version": "1.0.0",
  "description": "Node backend for the Omen frontend.",
  "type": "module",
  "main": "dist/backend/src/index.js",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "mcp:host": "tsx src/scripts/omen-mcp-host.ts",
    "run:scheduled": "tsx src/scripts/run-scheduled-cycle.ts",
    "run:scheduled:prod": "tsx src/scripts/run-scheduled-cycle.ts",
    "smoke:live": "tsx src/scripts/smoke-live-swarm.ts",
    "lint": "eslint \"src/**/*.ts\" --no-error-on-unmatched-pattern",
    "lint:fix": "eslint \"src/**/*.ts\" --fix --no-error-on-unmatched-pattern",
    "test": "node -e \"process.exit(0)\"",
    "typecheck": "tsc --noEmit --project tsconfig.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/lib-storage": "^3.1037.0",
    "@gradio/client": "^2.2.0",
    "@omen/agents": "workspace:*",
    "@omen/axl": "workspace:*",
    "@omen/db": "workspace:*",
    "@omen/market-data": "workspace:*",
    "@omen/shared": "workspace:*",
    "@omen/zero-g": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "sharp": "^0.34.5",
    "tsx": "^4.19.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
