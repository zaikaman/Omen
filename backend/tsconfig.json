{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "rootDir": "..",
    "outDir": "./dist",
    "baseUrl": "..",
    "noEmit": false,
    "types": ["node"],
    "paths": {
      "@omen/agents": ["packages/agents/src"],
      "@omen/axl": ["packages/axl/src"],
      "@omen/db": ["packages/db/src"],
      "@omen/execution": ["packages/execution/src"],
      "@omen/indicators": ["packages/indicators/src"],
      "@omen/market-data": ["packages/market-data/src"],
      "@omen/shared": ["packages/shared/src"],
      "@omen/zero-g": ["packages/zero-g/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
