NODE_ENV=production
LOG_LEVEL=info
RUNTIME_MODE=production_like
ALLOW_CONCURRENT_RUNS=false
SCHEDULER_ENABLED=true

FRONTEND_URL=https://your-omen-frontend.vercel.app
FRONTEND_ORIGIN=https://your-omen-frontend.vercel.app

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_SCHEMA=public

OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5-nano

SCANNER_API_KEY=your_scanner_api_key
SCANNER_BASE_URL=https://v98store.com/v1
SCANNER_MODEL=grok-4-fast

TAVILY_API_KEY=your_tavily_api_key
COINGECKO_API_KEY=your_coingecko_api_key
COINGECKO_API_KEY_1=your_first_coingecko_api_key
HF_TOKEN=your_huggingface_api_token

R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_PUBLIC_URL=https://your_r2_public_url

TWITTERAPI_BASE_URL=https://api.twitterapi.io
TWITTERAPI_API_KEY=your_twitterapi_io_key
TWITTERAPI_LOGIN_COOKIES=your_login_cookies_blob
TWITTERAPI_PROXY=host:port:user:pass

AXL_NODE_BASE_URL=https://your-omen-axl.fly.dev
AXL_API_TOKEN=your_shared_axl_bridge_token
AXL_ORCHESTRATOR_NODE_ID=omen-orchestrator
AXL_SCANNER_NODE_ID=omen-scanner
AXL_RESEARCH_NODE_ID=omen-research
AXL_ANALYST_NODE_ID=omen-analyst
AXL_CRITIC_NODE_ID=omen-critic

ZERO_G_RPC_URL=https://evmrpc-testnet.0g.ai
ZERO_G_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
ZERO_G_KV_NODE_URL=https://your-0g-kv-node
ZERO_G_COMPUTE_URL=https://your-0g-compute-endpoint
ZERO_G_COMPUTE_API_KEY=app-sk-your-0g-compute-secret
ZERO_G_PRIVATE_KEY=0xyour_0g_wallet_private_key
ZERO_G_FLOW_CONTRACT_ADDRESS=0xoptional_flow_contract_override
