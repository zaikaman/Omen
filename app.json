{
  "name": "omen-backend",
  "description": "Omen hourly swarm backend for Heroku deployment.",
  "repository": "https://github.com/your-org/omen",
  "env": {
    "NODE_ENV": {
      "value": "production"
    },
    "NPM_CONFIG_PRODUCTION": {
      "value": "true"
    },
    "LOG_LEVEL": {
      "value": "info"
    },
    "RUNTIME_MODE": {
      "value": "production_like"
    },
    "ALLOW_CONCURRENT_RUNS": {
      "value": "false"
    },
    "SCHEDULER_ENABLED": {
      "value": "true"
    },
    "FRONTEND_URL": {
      "required": true
    },
    "FRONTEND_ORIGIN": {
      "required": true
    },
    "SUPABASE_URL": {
      "required": true
    },
    "SUPABASE_SERVICE_ROLE_KEY": {
      "required": true
    },
    "SUPABASE_SCHEMA": {
      "value": "public"
    },
    "OPENAI_API_KEY": {
      "required": true
    },
    "OPENAI_BASE_URL": {
      "value": "https://api.openai.com/v1"
    },
    "OPENAI_MODEL": {
      "value": "gpt-5-nano"
    },
    "SCANNER_API_KEY": {
      "required": true
    },
    "SCANNER_BASE_URL": {
      "value": "https://v98store.com/v1"
    },
    "SCANNER_MODEL": {
      "value": "grok-4-fast"
    },
    "TAVILY_API_KEY": {
      "required": true
    },
    "COINGECKO_API_KEY": {
      "required": false
    },
    "HF_TOKEN": {
      "required": false
    },
    "TWITTERAPI_BASE_URL": {
      "value": "https://api.twitterapi.io"
    },
    "TWITTERAPI_API_KEY": {
      "required": true
    },
    "TWITTERAPI_LOGIN_COOKIES": {
      "required": true
    },
    "TWITTERAPI_PROXY": {
      "required": true
    },
    "AXL_NODE_BASE_URL": {
      "required": true
    },
    "AXL_API_TOKEN": {
      "required": false
    },
    "AXL_REQUEST_TIMEOUT_MS": {
      "required": false,
      "value": "30000"
    },
    "AXL_SERVICE_PEER_ID": {
      "required": false
    },
    "ZERO_G_RPC_URL": {
      "value": "https://evmrpc-testnet.0g.ai"
    },
    "ZERO_G_INDEXER_URL": {
      "value": "https://indexer-storage-testnet-turbo.0g.ai"
    },
    "ZERO_G_KV_NODE_URL": {
      "required": true
    },
    "ZERO_G_COMPUTE_URL": {
      "required": true
    },
    "ZERO_G_COMPUTE_API_KEY": {
      "required": true
    },
    "ZERO_G_PRIVATE_KEY": {
      "required": true
    },
    "ZERO_G_FLOW_CONTRACT_ADDRESS": {
      "required": false
    },
    "ZERO_G_CHECKPOINT_STRATEGY": {
      "value": "milestone"
    },
    "R2_ACCOUNT_ID": {
      "required": false
    },
    "R2_ACCESS_KEY_ID": {
      "required": false
    },
    "R2_SECRET_ACCESS_KEY": {
      "required": false
    },
    "R2_BUCKET_NAME": {
      "value": "omen"
    },
    "R2_PUBLIC_URL": {
      "required": false
    }
  }
}
