{
  "name": "@omen/runtime",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit --project ../../tsconfig.json",
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "lint": "eslint \"**/*.{ts,tsx,mts,cts,mjs}\" --no-error-on-unmatched-pattern",
    "lint:fix": "eslint \"**/*.{ts,tsx,mts,cts,mjs}\" --fix --no-error-on-unmatched-pattern",
    "start": "dotenv -e ../../.env -- tsx src/index.ts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit --project ../../tsconfig.json"
  },
  "dependencies": {
    "@omen/agents": "workspace:*",
    "@omen/axl": "workspace:*",
    "@omen/db": "workspace:*",
    "@omen/execution": "workspace:*",
    "@omen/market-data": "workspace:*",
    "@omen/shared": "workspace:*",
    "@omen/zero-g": "workspace:*",
    "zod": "^3.24.3"
  }
}
