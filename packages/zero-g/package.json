{
  "name": "@omen/zero-g",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc --noEmit --project ../../tsconfig.json",
    "deploy:run-registry": "tsx src/scripts/deploy-run-registry.ts",
    "lint": "eslint \"**/*.{ts,tsx,mts,cts,mjs}\" --no-error-on-unmatched-pattern",
    "lint:fix": "eslint \"**/*.{ts,tsx,mts,cts,mjs}\" --fix --no-error-on-unmatched-pattern",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit --project ../../tsconfig.json"
  },
  "dependencies": {
    "@0gfoundation/0g-ts-sdk": "1.2.4",
    "@omen/shared": "workspace:*",
    "ethers": "6.13.1",
    "zod": "^3.24.3"
  }
}
