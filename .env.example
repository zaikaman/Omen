# Omen runtime env surface currently used by the active MVP code paths.
# This is intentionally trimmed to the env vars that are read today.

NODE_ENV=development
LOG_LEVEL=info
WEB_PORT=5173
PORT=4001
RUNTIME_MODE=production_like
ALLOW_CONCURRENT_RUNS=false

FRONTEND_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:4001/api

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5-mini

SCANNER_API_KEY=your_scanner_api_key
SCANNER_BASE_URL=https://v98store.com/v1
SCANNER_MODEL=grok-4-fast

TAVILY_API_KEY=your_tavily_api_key
COINGECKO_API_KEY=your_coingecko_api_key
