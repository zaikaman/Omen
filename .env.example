# Shared root environment for the entire Omen workspace.
# Copy this file to .env and update the values for local development.

NODE_ENV=development
WEB_PORT=3000
RUNTIME_PORT=4001
RUNTIME_MODE=mocked-demo
ALLOW_CONCURRENT_RUNS=false
ENABLE_MAINNET_EXECUTION=false

NEXT_PUBLIC_APP_NAME=Omen
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_DB_PASSWORD=your-local-supabase-db-password
SUPABASE_PROJECT_ID=your-supabase-project-id

AXL_NODE_BASE_URL=http://127.0.0.1:8080
AXL_ORCHESTRATOR_NODE_ID=omen-orchestrator
AXL_SCANNER_NODE_ID=omen-scanner
AXL_RESEARCH_NODE_ID=omen-research
AXL_ANALYST_NODE_ID=omen-analyst
AXL_CRITIC_NODE_ID=omen-critic

ZERO_G_RPC_URL=https://rpc-testnet.0g.ai
ZERO_G_INDEXER_URL=https://indexer-testnet.0g.ai
ZERO_G_COMPUTE_URL=https://compute-testnet.0g.ai
ZERO_G_PRIVATE_KEY=replace-me
