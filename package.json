{
  "name": "omen",
  "private": true,
  "version": "0.1.0",
  "description": "Omen autonomous market-intelligence swarm monorepo.",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "backend": "pnpm --dir backend dev",
    "build": "turbo run build",
    "clean": "turbo run clean --force",
    "dev": "turbo run dev --parallel",
    "frontend": "pnpm --dir frontend dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "heroku-postbuild": "pnpm --filter omen-backend build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "start:backend": "pnpm --dir backend start",
    "typecheck": "turbo run typecheck",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:unit": "turbo run test",
    "test:integration": "vitest run tests/integration --passWithNoTests",
    "test:e2e": "playwright test",
    "supabase:start": "pnpm dlx supabase start",
    "supabase:stop": "pnpm dlx supabase stop",
    "supabase:status": "pnpm dlx supabase status",
    "supabase:reset": "pnpm dlx supabase db reset",
    "axl:help": "node -e \"console.log('Root AXL helpers are wired through package.json. Phase 6 will replace these placeholders with scripts/axl/*.ps1 helpers.')\"",
    "axl:start:orchestrator": "node -e \"console.log('Planned helper: scripts/axl/start-orchestrator-node.ps1')\"",
    "axl:start:scanner": "node -e \"console.log('Planned helper: scripts/axl/start-scanner-node.ps1')\"",
    "axl:start:research": "node -e \"console.log('Planned helper: scripts/axl/start-research-node.ps1')\"",
    "axl:start:analyst": "node -e \"console.log('Planned helper: scripts/axl/start-analyst-node.ps1')\"",
    "axl:start:critic": "node -e \"console.log('Planned helper: scripts/axl/start-critic-node.ps1')\""
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@next/eslint-plugin-next": "^15.3.1",
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.18",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "dotenv-cli": "^7.4.2",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.1.2"
  }
}
