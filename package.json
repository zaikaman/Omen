{
  "name": "omen",
  "private": true,
  "version": "0.1.0",
  "description": "Omen autonomous market-intelligence swarm monorepo.",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "omen-backend": "workspace:*"
  },
  "scripts": {
    "backend": "pnpm --dir backend dev",
    "build": "turbo run build",
    "clean": "turbo run clean --force",
    "dev": "turbo run dev --parallel",
    "frontend": "pnpm --dir frontend dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "heroku-postbuild": "node -e \"console.log('Skipping Heroku build: backend runs TypeScript through tsx at runtime.')\"",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "start:backend": "pnpm --dir backend start",
    "typecheck": "turbo run typecheck",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:unit": "turbo run test",
    "test:integration": "vitest run tests/integration --passWithNoTests",
    "test:e2e": "playwright test",
    "supabase:start": "pnpm dlx supabase start",
    "supabase:stop": "pnpm dlx supabase stop",
    "supabase:status": "pnpm dlx supabase status",
    "supabase:reset": "pnpm dlx supabase db reset",
    "axl:help": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/axl/start-demo-swarm.ps1 -?",
    "axl:start:demo": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/axl/start-demo-swarm.ps1",
    "axl:start:demo:core": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/axl/start-demo-swarm.ps1 -Profile core",
    "axl:stop:demo": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/axl/stop-demo-swarm.ps1",
    "axl:verify:a2a": "tsx local/verify-axl-a2a.ts",
    "axl:start:orchestrator": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/axl/start-orchestrator-node.ps1",
    "axl:start:market-bias": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/axl/start-market-bias-node.ps1",
    "axl:start:scanner": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/axl/start-scanner-node.ps1",
    "axl:start:research": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/axl/start-research-node.ps1",
    "axl:start:chart-vision": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/axl/start-chart-vision-node.ps1",
    "axl:start:analyst": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/axl/start-analyst-node.ps1",
    "axl:start:critic": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/axl/start-critic-node.ps1",
    "axl:start:intel": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/axl/start-intel-node.ps1",
    "axl:start:generator": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/axl/start-generator-node.ps1",
    "axl:start:writer": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/axl/start-writer-node.ps1",
    "axl:start:publisher": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/axl/start-publisher-node.ps1",
    "axl:start:memory": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/axl/start-memory-node.ps1"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@next/eslint-plugin-next": "^15.3.1",
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.18",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "dotenv-cli": "^7.4.2",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.1.2"
  }
}
